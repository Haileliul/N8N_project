    {
      "parameters": {
        "jsCode": "for (const item of $input.all()) {\n  // Check if the binary property 'Report' exists\n  if (item.binary && item.binary.Report) {\n    // Update the metadata to PDF\n    item.binary.Report.fileName = 'Report.pdf';\n    item.binary.Report.mimeType = 'application/pdf';\n    item.binary.Report.fileExtension = 'pdf';\n  }\n}\nreturn $input.all();"
      },
